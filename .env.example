# Copy to .env and fill in values. Never commit .env.
# ---------- Core ----------
# PARCEL_ENV: one of dev | staging | prod
PARCEL_ENV=dev
PARCEL_HOST=0.0.0.0
PARCEL_PORT=8000
PARCEL_SESSION_SECRET=change-me-to-a-long-random-string

# ---------- Database ----------
DATABASE_URL=postgresql+asyncpg://parcel:parcel@postgres:5432/parcel

# ---------- Redis (ARQ background jobs, caching) ----------
REDIS_URL=redis://redis:6379/0

# ---------- AI (Phase 7) ----------
# Leave blank until Phase 7 is active.
ANTHROPIC_API_KEY=
PARCEL_AI_MODEL=claude-opus-4-7
PARCEL_AI_ENABLED=false
