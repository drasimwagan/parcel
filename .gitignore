# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
.eggs/
dist/
build/
wheels/
pip-wheel-metadata/
MANIFEST

# --- Virtual envs ---
.venv/
venv/
env/
ENV/

# --- uv ---
# Keep uv.lock committed for reproducibility; ignore caches only.
.uv-cache/

# --- Testing / coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# --- Type checkers / linters ---
.mypy_cache/
.pyright/
.ruff_cache/
.dmypy.json
dmypy.json

# --- Node (future tailwind build) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- IDEs / editors ---
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# --- Env / secrets ---
.env
.env.*
!.env.example

# --- Docker ---
.docker-data/
postgres-data/
redis-data/

# --- Alembic generated artifacts we don't want tracked ---
# (migrations themselves ARE tracked; only runtime artifacts are ignored)

# --- Claude Code ---
.claude/settings.local.json
.claude/plans/
.claude/memory/
.claude/logs/

# --- Parcel-specific runtime ---
/var/*
!/var/.gitkeep
/tmp/
sandbox-modules/
*.db
*.sqlite
*.sqlite3
.superpowers/
