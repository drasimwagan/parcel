{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(uv sync)",
      "Bash(uv sync:*)",
      "Bash(uv run:*)",
      "Bash(uv add:*)",
      "Bash(uv remove:*)",
      "Bash(uv lock)",
      "Bash(uv lock:*)",
      "Bash(uv pip:*)",
      "Bash(uv tree)",
      "Bash(pytest)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(pyright)",
      "Bash(pyright:*)",
      "Bash(alembic:*)",
      "Bash(docker compose:*)",
      "Bash(docker ps)",
      "Bash(docker logs:*)",
      "Bash(docker image ls)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git restore:*)",
      "Bash(git stash)",
      "Bash(git stash:*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(tree:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -rf /:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fdx:*)",
      "Bash(docker system prune:*)",
      "Bash(docker volume rm:*)",
      "Bash(DROP DATABASE:*)",
      "Bash(DROP SCHEMA:*)"
    ]
  }
}
